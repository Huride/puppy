{
  "name": "pawtrol",
  "version": "0.1.19",
  "description": "Pawtrol is Bori, a cute companion watching over your AI coding sessions.",
  "author": "Huride",
  "private": false,
  "type": "module",
  "main": "dist/src/desktop/main.js",
  "bin": {
    "pawtrol": "dist/src/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/src/cli.js && mkdir -p dist/src/overlay && cp src/overlay/index.html dist/src/overlay/index.html && cp src/overlay/styles.css dist/src/overlay/styles.css && rm -rf dist/src/overlay/assets && cp -R src/overlay/assets dist/src/overlay/assets",
    "test": "vitest run",
    "prepare": "npm run build",
    "auth:check": "npm run build && node scripts/auth-check.mjs",
    "start": "npm run app",
    "app": "npm run app:dev",
    "run:dev": "npm run app:dev",
    "dev": "tsx src/cli.ts",
    "demo:gif": "node scripts/generate-readme-demo-gif.mjs",
    "watch:demo": "tsx src/cli.ts watch -- node scripts/demo-agent.mjs",
    "app:dev": "npm run build && electron dist/src/desktop/main.js",
    "app:pack": "npm run build && electron-builder --dir",
    "app:dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "dotenv": "^16.4.7",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "files": [
    "dist/src",
    "scripts/demo-agent.mjs",
    "scripts/auth-check.mjs",
    "README.md",
    ".env.example"
  ],
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.huride.pawtrol",
    "productName": "Pawtrol",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "scripts/demo-agent.mjs",
      "package.json"
    ],
    "asarUnpack": [
      "dist/**/*",
      "scripts/demo-agent.mjs"
    ],
    "extraMetadata": {
      "main": "dist/src/desktop/main.js"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Huride",
        "repo": "puppy"
      }
    ]
  },
  "optionalDependencies": {
    "electron": "^41.3.0"
  }
}
